{
  "entity": "MJ: Dashboards",
  "filePattern": "**/.*.json",
  "defaults": {},
  "pull": {
    "createNewFileIfNotFound": true,
    "newFileName": ".dashboards.json",
    "appendRecordsToExistingFile": true,
    "updateExistingRecords": true,
    "preserveFields": [],
    "excludeFields": [],
    "mergeStrategy": "merge",
    "backupBeforeUpdate": true,
    "backupDirectory": ".backups",
    "filter": "DriverClass='FormsReportingDashboard'",
    "externalizeFields": [],
    "ignoreNullFields": true,
    "ignoreVirtualFields": true,
    "lookupFields": {
      "ApplicationID": {
        "entity": "MJ: Applications",
        "field": "Name"
      },
      "EnvironmentID": {
        "entity": "MJ: Environments",
        "field": "Name"
      }
    },
    "relatedEntities": {}
  }
}
