      "DefaultForNewUser": false,
      "DefaultNavItems": [
        {
          "Label": "Form Builder",
          "Icon": "fa-solid fa-pen-ruler",
          "ResourceType": "Custom",
          "DriverClass": "FormsBuilderResource",
          "isDefault": true
        },
        {
          "Label": "All Forms",
          "Icon": "fa-solid fa-clipboard-list",
